# Required — copy to .env.local and fill in your deployed stack URLs
VITE_WEBSOCKET_URL=wss://YOUR_WEBSOCKET_API_ID.execute-api.us-east-1.amazonaws.com/dev
VITE_API_URL=https://YOUR_REST_API_ID.execute-api.us-east-1.amazonaws.com/dev

# Optional — only set if running a local/separate Nova Sonic voice streaming server.
# Without this, the voice microphone button is disabled.
# VITE_VOICE_WS_URL=ws://localhost:8081

VITE_MAX_FILE_SIZE=10485760
VITE_SUPPORTED_AUDIO_FORMATS=audio/webm,audio/wav
